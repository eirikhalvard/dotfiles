{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "bg": "#fffcf0",
    "bgAlt": "#f2f0e5",
    "bgPanel": "#e6e4d9",
    "fg": "#100f0f",
    "fgMuted": "#6f6e69",
    "red": "#af3029",
    "redBright": "#d14d41",
    "green": "#66800b",
    "greenBright": "#879a39",
    "yellow": "#ad8301",
    "yellowBright": "#d0a215",
    "blue": "#205ea6",
    "blueBright": "#4385be",
    "magenta": "#a02f6f",
    "magentaBright": "#ce5d97",
    "cyan": "#24837b",
    "cyanBright": "#3aa99f",
    "surface": "#cecdc3",
    "surfaceMuted": "#b7b5ac"
  },
  "theme": {
    "primary": { "dark": "blue", "light": "blue" },
    "secondary": { "dark": "magenta", "light": "magenta" },
    "accent": { "dark": "cyan", "light": "cyan" },
    "error": { "dark": "red", "light": "red" },
    "warning": { "dark": "yellow", "light": "yellow" },
    "success": { "dark": "green", "light": "green" },
    "info": { "dark": "blueBright", "light": "blueBright" },
    "text": { "dark": "fg", "light": "fg" },
    "textMuted": { "dark": "fgMuted", "light": "fgMuted" },
    "background": { "dark": "bg", "light": "bg" },
    "backgroundPanel": { "dark": "bgAlt", "light": "bgAlt" },
    "backgroundElement": { "dark": "bgPanel", "light": "bgPanel" },
    "border": { "dark": "surface", "light": "surface" },
    "borderActive": { "dark": "blue", "light": "blue" },
    "borderSubtle": { "dark": "surfaceMuted", "light": "surfaceMuted" },
    "diffAdded": { "dark": "green", "light": "green" },
    "diffRemoved": { "dark": "red", "light": "red" },
    "diffContext": { "dark": "fgMuted", "light": "fgMuted" },
    "diffHunkHeader": { "dark": "cyan", "light": "cyan" },
    "diffHighlightAdded": { "dark": "greenBright", "light": "greenBright" },
    "diffHighlightRemoved": { "dark": "redBright", "light": "redBright" },
    "diffAddedBg": { "dark": "#e8f0dc", "light": "#e8f0dc" },
    "diffRemovedBg": { "dark": "#f5e5e3", "light": "#f5e5e3" },
    "diffContextBg": { "dark": "bgAlt", "light": "bgAlt" },
    "diffLineNumber": { "dark": "surfaceMuted", "light": "surfaceMuted" },
    "diffAddedLineNumberBg": { "dark": "#dde8cf", "light": "#dde8cf" },
    "diffRemovedLineNumberBg": { "dark": "#ebdad8", "light": "#ebdad8" },
    "markdownText": { "dark": "fg", "light": "fg" },
    "markdownHeading": { "dark": "magenta", "light": "magenta" },
    "markdownLink": { "dark": "blue", "light": "blue" },
    "markdownLinkText": { "dark": "cyan", "light": "cyan" },
    "markdownCode": { "dark": "green", "light": "green" },
    "markdownBlockQuote": { "dark": "fgMuted", "light": "fgMuted" },
    "markdownEmph": { "dark": "yellow", "light": "yellow" },
    "markdownStrong": { "dark": "yellowBright", "light": "yellowBright" },
    "markdownHorizontalRule": { "dark": "fgMuted", "light": "fgMuted" },
    "markdownListItem": { "dark": "blue", "light": "blue" },
    "markdownListEnumeration": { "dark": "cyan", "light": "cyan" },
    "markdownImage": { "dark": "blue", "light": "blue" },
    "markdownImageText": { "dark": "cyan", "light": "cyan" },
    "markdownCodeBlock": { "dark": "fg", "light": "fg" },
    "syntaxComment": { "dark": "fgMuted", "light": "fgMuted" },
    "syntaxKeyword": { "dark": "magenta", "light": "magenta" },
    "syntaxFunction": { "dark": "blue", "light": "blue" },
    "syntaxVariable": { "dark": "red", "light": "red" },
    "syntaxString": { "dark": "green", "light": "green" },
    "syntaxNumber": { "dark": "yellowBright", "light": "yellowBright" },
    "syntaxType": { "dark": "yellow", "light": "yellow" },
    "syntaxOperator": { "dark": "cyan", "light": "cyan" },
    "syntaxPunctuation": { "dark": "fg", "light": "fg" }
  }
}
