{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "neonGreen": "#21f6bc",
    "green": "#00fbac",
    "cyan": "#86cbfe",
    "blue": "#00bfff",
    "magenta": "#df95ff",
    "pink": "#f4b8e4",
    "red": "#ff7092",
    "yellow": "#fffa6a",
    "peach": "#ef9f76",
    "text": "#e5e5e5",
    "subtext1": "#c5c5c5",
    "subtext0": "#a5adce",
    "overlay2": "#949cb8",
    "overlay1": "#838ba7",
    "overlay0": "#737994",
    "surface2": "#524878",
    "surface1": "#453d68",
    "surface0": "#3d3560",
    "base": "#332a57",
    "mantle": "#2a2248",
    "crust": "#221c3d"
  },
  "theme": {
    "primary": {
      "dark": "neonGreen",
      "light": "neonGreen"
    },
    "secondary": {
      "dark": "magenta",
      "light": "magenta"
    },
    "accent": {
      "dark": "cyan",
      "light": "cyan"
    },
    "error": {
      "dark": "red",
      "light": "red"
    },
    "warning": {
      "dark": "yellow",
      "light": "yellow"
    },
    "success": {
      "dark": "green",
      "light": "green"
    },
    "info": {
      "dark": "blue",
      "light": "blue"
    },
    "text": {
      "dark": "text",
      "light": "text"
    },
    "textMuted": {
      "dark": "subtext1",
      "light": "subtext1"
    },
    "background": {
      "dark": "base",
      "light": "base"
    },
    "backgroundPanel": {
      "dark": "mantle",
      "light": "mantle"
    },
    "backgroundElement": {
      "dark": "crust",
      "light": "crust"
    },
    "border": {
      "dark": "surface0",
      "light": "surface0"
