    },
    "markdownText": {
      "dark": "text",
      "light": "text"
    },
    "markdownHeading": {
      "dark": "neonGreen",
      "light": "neonGreen"
    },
    "markdownLink": {
      "dark": "blue",
      "light": "blue"
    },
    "markdownLinkText": {
      "dark": "cyan",
      "light": "cyan"
    },
    "markdownCode": {
      "dark": "magenta",
      "light": "magenta"
    },
    "markdownBlockQuote": {
      "dark": "yellow",
      "light": "yellow"
    },
    "markdownEmph": {
      "dark": "yellow",
      "light": "yellow"
    },
    "markdownStrong": {
      "dark": "peach",
      "light": "peach"
    },
    "markdownHorizontalRule": {
      "dark": "subtext0",
      "light": "subtext0"
    },
    "markdownListItem": {
      "dark": "cyan",
      "light": "cyan"
    },
    "markdownListEnumeration": {
      "dark": "blue",
      "light": "blue"
