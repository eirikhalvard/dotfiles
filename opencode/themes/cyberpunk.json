    "diffHighlightAdded": {
      "dark": "neonGreen",
      "light": "neonGreen"
    },
    "diffHighlightRemoved": {
      "dark": "red",
      "light": "red"
    },
    "diffAddedBg": {
      "dark": "#2a3d35",
      "light": "#2a3d35"
    },
    "diffRemovedBg": {
      "dark": "#3d2a35",
      "light": "#3d2a35"
    },
    "diffContextBg": {
      "dark": "mantle",
      "light": "mantle"
    },
    "diffLineNumber": {
      "dark": "surface1",
      "light": "surface1"
