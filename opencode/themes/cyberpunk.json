      "dark": "overlay2",
      "light": "overlay2"
    },
    "syntaxKeyword": {
      "dark": "magenta",
      "light": "magenta"
    },
    "syntaxFunction": {
      "dark": "neonGreen",
      "light": "neonGreen"
    },
    "syntaxVariable": {
      "dark": "cyan",
      "light": "cyan"
    },
    "syntaxString": {
      "dark": "yellow",
      "light": "yellow"
    },
    "syntaxNumber": {
      "dark": "peach",
      "light": "peach"
    },
    "syntaxType": {
      "dark": "blue",
      "light": "blue"
    },
    "syntaxOperator": {
      "dark": "red",
      "light": "red"
    },
    "syntaxPunctuation": {
      "dark": "text",
      "light": "text"
    }
