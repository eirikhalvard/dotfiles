# Usage: kubectl logs POD | klogs
klogs() {
    grep -E "^\{.*\}$" | jq -r '
  "\u001b[36m\(.["@timestamp"])\u001b[0m " +
  (if .level == "ERROR" then "\u001b[31m[ERROR]\u001b[0m"
   elif .level == "WARN" then "\u001b[33m[WARN]\u001b[0m"
   elif .level == "INFO" then "\u001b[32m[INFO]\u001b[0m"
   else "[\(.level)]" end) +
  " \(.message)"
    '
}

##################### FUNCTIONS ###########################

unalias z 2> /dev/null
z() {
    [ $# -gt 0 ] && zshz "$*" && return
    cd "$(zshz -l 2>&1 | fzf --height 40% --nth 2.. --reverse --inline-info +s --tac --query "${*##-* }" | sed 's/^[0-9,.]* *//')"
}

THEME_STATE="$HOME/.config/shell/theme-mode"
export THEME_MODE="$(cat "$THEME_STATE" 2>/dev/null || echo dark)"
_apply_theme_env() {
  export THEME_IS_LIGHT=false
  local mode="dark"

  if [[ "$THEME_MODE" == "light" ]]; then
    export THEME_IS_LIGHT=true
    mode="light"
  fi

  # Symlink configs to the appropriate theme variant
  ln -sf ~/.config/ghostty/config.$mode ~/.config/ghostty/config
  ln -sf ~/.config/k9s/config.$mode.yaml ~/.config/k9s/config.yaml
  ln -sf ~/.config/opencode/tui.$mode.json ~/.config/opencode/tui.json
}
_apply_theme_env

light() {
  export THEME_MODE=light
  echo light > "$THEME_STATE"
  _apply_theme_env
}

dark() {
  export THEME_MODE=dark
  echo dark > "$THEME_STATE"
  _apply_theme_env
}

