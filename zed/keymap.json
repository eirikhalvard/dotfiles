// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "bindings": {
      "cmd-o": "file_finder::Toggle",
    },
  },
  {
    "context": "vim_mode == normal && !menu",
    "bindings": {
      // ---------- Basic mappings (matches ideavimrc) ----------
      ", w": "workspace::Save",
      ", q": "pane::CloseActiveItem",
      ", ,": "pane::AlternateFile",

      // Y to yank to end of line (like ideavimrc)
      "shift-y": "vim::YankToEndOfLine",

      // ---------- Pane navigation ----------
      "shift-h": "workspace::ActivatePaneLeft",
      "shift-l": "workspace::ActivatePaneRight",
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",

      // ---------- Tab navigation ----------
      "ctrl-tab": "pane::ActivateNextItem",
      "ctrl-shift-tab": "pane::ActivatePreviousItem",

      // ---------- Recent/switch ----------
      ", r": "projects::OpenRecent",

      // ---------- Find mappings (<leader>f_) ----------
      ", f f": "file_finder::Toggle",
      ", f s": "project_symbols::Toggle",
      ", f a": "command_palette::Toggle",

      // ---------- Edit mappings (<leader>e_) ----------
      ", e s": "buffer_search::DeployReplace",

      // ---------- Do mappings (<leader>d_) ----------
      ", d f": "editor::Format",

      // ---------- Smart mappings (<leader>s_) ----------
      ", s e": "editor::GoToDiagnostic",
      ", s f": "pane::DeploySearch",
      ", s r": ["pane::DeploySearch", { "replace_enabled": true }],
      ", s s": "editor::ToggleCodeActions",
      ", s t": "project_symbols::Toggle",

      // ---------- Toggle mappings (<leader>t_) ----------
      ", t t": "project_panel::ToggleFocus",

      // ---------- Git mappings (<leader>g_) ----------
      ", g u": "git::Restore",

      // ---------- g mappings (LSP navigation) ----------
      "g d": "editor::GoToDefinition",
      "g shift-d": "editor::GoToTypeDefinition",
      "g r": "editor::FindAllReferences",
      "g i": "editor::GoToImplementation",
    },
  },
  {
    "context": "vim_mode == visual && !menu",
    "bindings": {
      ", e s": "buffer_search::DeployReplace",
      ", d f": "editor::Format",
      ", s f": ["pane::DeploySearch", { "replace_enabled": false }],
      ", s r": ["pane::DeploySearch", { "replace_enabled": true }],
      ", s s": "editor::ToggleCodeActions",
      ", g u": "git::Restore",
    },
  },
]
